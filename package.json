    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.3",
    "supabase": "^2.104.0",
